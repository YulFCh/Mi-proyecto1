    <script>
                // PREVIEW ANTES DE SUBIR
        document.getElementById("fileImage").addEventListener("change", function (e) {

            const file = e.target.files[0];

            if (file) {
                const reader = new FileReader();

                reader.onload = function (event) {
                    const img = document.getElementById("previewImage");
                    img.src = event.target.result;
                    img.style.display = "block";
                };

                reader.readAsDataURL(file);
            }
        });

                async function subirImagen() {

            const file = document.getElementById("fileImage").files[0];

            if (!file) {
                alert("Selecciona una imagen");
                return;
            }

            const formData = new FormData();
            formData.append("file", file);
            formData.append("upload_preset", "inventario_preset");

            const response = await fetch(
                "https://api.cloudinary.com/v1_1/dkxto4ymq/image/upload",
                {
                    method: "POST",
                    body: formData
                }
            );

            const data = await response.json();

            console.log("URL:", data.secure_url);

            guardarEnApi(data.secure_url);
        }


                function guardarEnApi(urlImagen) {

            fetch("https://mi-proyecto1-2.onrender.com/api/registros", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    tipo_equipo: "Laptop",
                    color: "Negro",
                    modelo: "Dell",
                    descripcion: "Equipo desde modal",
                    precio: 2500,
                    url_equipo: urlImagen
                })
            })
            .then(r => r.json())
            .then(data => {
                alert("Imagen guardada correctamente 🚀");

                // cerrar modal
                $('#modalActualizar').modal('hide');

                // limpiar input
                document.getElementById("fileImage").value = "";
                document.getElementById("previewImage").style.display = "none";
            })
            .catch(err => {
                console.error(err);
                alert("Error al guardar");
            });
        }

    </script>


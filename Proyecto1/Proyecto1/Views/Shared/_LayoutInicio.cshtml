@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@(ViewData["Title"] ?? "FRACTÁLICA")</title>

    <link rel="stylesheet" href="~/assets/css/style.css" />
    <link rel="stylesheet" href="~/css/styleModal.css" />

</head>

<body>

    <!-- HEADER -->
    <header class="modern-header">

        <div style="display:flex;justify-content:space-between;align-items:center;">

            <h2 style="margin:0;">fractálica</h2>

            <!-- BOTÓN LOGIN -->
            <button class="btn modern-login-btn"
                    data-toggle="modal"
                    data-target="#loginModal">

                Inicio de sesión

            </button>

        </div>

    </header>

    <!-- CONTENIDO -->
    <div class="container">
        @RenderBody()
    </div>

    <!-- MODAL LOGIN -->
    <div class="modal fade" id="loginModal" tabindex="-1" role="dialog" aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered" role="document">

            <div class="modal-content modern-modal">

                <!-- HEADER -->
                <div class="modal-header border-0">

                    <div>
                        <h3 class="modal-title modern-title">
                            Bienvenido
                        </h3>
                    </div>

                    <button type="button"
                            class="close modern-close"
                            data-dismiss="modal"
                            aria-label="Close">

                        <span>&times;</span>

                    </button>

                </div>

                @{
                    var loginError = TempData["LoginError"] as string;
                }

                <!-- BODY -->
                <div class="modal-body pt-0">

                    @if (!string.IsNullOrEmpty(loginError))
                    {
                        <div class="alert alert-danger modern-alert">
                            @loginError
                        </div>
                    }

                    <form asp-controller="Login"
                          asp-action="Index"
                          method="post">

                        <div class="form-group">

                            <label class="modern-label">
                                Usuario
                            </label>

                            <input type="text"
                                   class="form-control modern-input"
                                   name="Usuario"
                                   placeholder="Ingrese usuario" />

                        </div>

                        <div class="form-group">

                            <label class="modern-label">
                                Contraseña
                            </label>

                            <input type="password"
                                   class="form-control modern-input"
                                   name="Password"
                                   placeholder="Ingrese contraseña" />

                        </div>

                        <button type="submit"
                                class="btn modern-btn btn-block">

                            Iniciar sesión

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

    <!-- JS NECESARIO PARA MODALES -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/assets/js/vendor-all.min.js"></script>
    <script src="~/assets/plugins/bootstrap/js/bootstrap.min.js"></script>

    @if (TempData["LoginError"] != null)
    {
        <script>
            $(document).ready(function () {
                $('#loginModal').modal('show');
            });
        </script>
    }

</body>

</html>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@(ViewData["Title"] ?? "Sistema Inventario")</title>

    <link rel="stylesheet" href="~/assets/css/style.css" />

</head>

<body>

    <!-- HEADER -->
    <header style="background:#343a40;color:white;padding:15px;">

        <div style="display:flex;justify-content:space-between;align-items:center;">

            <h2 style="margin:0;">Sistema de Inventario</h2>

            <!-- BOTÓN LOGIN -->
            <button class="btn btn-primary"
                    data-toggle="modal"
                    data-target="#loginModal">
                Inicio de sesión
            </button>

        </div>

    </header>

    <!-- CONTENIDO -->
    <div class="container">
        @RenderBody()
    </div>

    <!-- MODAL LOGIN -->
    <div class="modal fade" id="loginModal" tabindex="-1" role="dialog" aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered" role="document">

            <div class="modal-content">

                <!-- HEADER -->
                <div class="modal-header">
                    <h5 class="modal-title">Inicio de sesión</h5>

                    <button type="button"
                            class="close"
                            data-dismiss="modal"
                            aria-label="Close">
                        <span>&times;</span>
                    </button>
                </div>

                @{
                    var loginError = TempData["LoginError"] as string;
                }

                <!-- BODY -->
                <div class="modal-body">

                    @if (!string.IsNullOrEmpty(loginError))
                    {
                        <div class="alert alert-danger">
                            @loginError
                        </div>
                    }

                    <form asp-controller="Login" asp-action="Index" method="post">

                        <div class="form-group">
                            <input type="text"
                                   class="form-control"
                                   name="Usuario"
                                   placeholder="Usuario" />
                        </div>

                        <div class="form-group">
                            <input type="password"
                                   class="form-control"
                                   name="Password"
                                   placeholder="Contraseña" />
                        </div>

                        <button type="submit" class="btn btn-primary btn-block">
                            Iniciar sesión
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

    <!-- JS NECESARIO PARA MODALES -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/assets/js/vendor-all.min.js"></script>
    <script src="~/assets/plugins/bootstrap/js/bootstrap.min.js"></script>

    @if (TempData["LoginError"] != null)
    {
        <script>
            $(document).ready(function () {
                $('#loginModal').modal('show');
            });
        </script>
    }

</body>

</html>
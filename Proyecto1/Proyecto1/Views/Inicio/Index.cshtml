@model Proyecto1.Views.Inicio.IndexModel
@{
    ViewData["Title"] = "Inicio";

    var estaLogueado = User.Identity.IsAuthenticated;

    Layout = estaLogueado
        ? "~/Views/Shared/_LayoutNavegador.cshtml"
        : "~/Views/Shared/_LayoutInicio.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<head>

    <link rel="stylesheet" href="~/css/styleInicio.css" />
    

</head>

@if (User.Identity.IsAuthenticated)
{
    <button type="button"
            class="btn btn-success"
            data-bs-toggle="modal"
            data-bs-target="#modalAgregar">
        Agregar Foto
    </button>
}

<div class="products-container" id="contenedorProductos">
</div>

<div class="modal fade"
     id="modalAgregar"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    Nuevo Equipo
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <form id="formNuevoEquipo" enctype="multipart/form-data">

                <div class="modal-body">

                    <div class="mb-3">
                        <label>Tipo Equipo</label>
                        <select id="tipoEquipo" class="form-control">

                            <option value="">Seleccione un tipo</option>
                            <option value="LAPTOP">LAPTOP</option>
                            <option value="CPU">CPU</option>
                            <option value="MONITOR">MONITOR</option>
                            <option value="TABLET">TABLET</option>
                            <option value="IMPRESORA">IMPRESORA</option>
                            <option value="ANTIVIRUS">ANTIVIRUS</option>

                        </select>
                    </div>

                    <div class="mb-3">
                        <label>Color</label>
                        <input type="text" id="color" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Modelo</label>
                        <input type="text" id="modelo" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Descripción</label>
                        <textarea id="descripcion" class="form-control"></textarea>
                    </div>

                    <div class="mb-3">
                        <label>Precio</label>
                        <input type="number" id="precio" step="0.01" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Imágenes del equipo (máx 4)</label>
                        <input type="file"
                               id="fileImage"
                               accept="image/*"
                               multiple
                               class="form-control" />
                    </div>

                    <!-- PREVIEW GRID -->
                    <div id="previewContainer"
                         style="display:flex; gap:10px; flex-wrap:wrap; margin-top:10px;">
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-primary w-100"
                            onclick="guardarEquipo()">
                        Guardar Equipo
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>


<div class="modal fade" id="modalZoom" tabindex="-1" aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Imagen</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body text-center position-relative"
                 style="height:600px; display:flex; align-items:center; justify-content:center;">

                <button id="btnPrev"
                        onclick="prevImage()"
                        style="position:absolute;left:10px;top:50%;transform:translateY(-50%);
                   background:none;border:none;font-size:30px;z-index:10;">
                    ◀
                </button>

                <img id="imgZoom"
                     style="max-width:100%; max-height:100%; object-fit:contain;" />

                <button id="btnNext"
                        onclick="nextImage()"
                        style="position:absolute;right:10px;top:50%;transform:translateY(-50%);
                   background:none;border:none;font-size:30px;z-index:10;">
                    ▶
                </button>

            </div>

        </div>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


<script>
    const estaLogueado = @User.Identity.IsAuthenticated.ToString().ToLower();
</script>


<script>

        let imagenesZoom = [];
    let indexZoom = 0;
    ///
    ////////////////////////////////////////////////////
    // =========================
    // CAMBIAR IMAGEN GALERÍA
    // =========================

    let imagenesEditando = [];
    let indiceArrastrado = null;


    function changeImage(element, targetId) {

        document.getElementById(targetId).src = element.src;

        element.parentNode.querySelectorAll('.thumbnail-image')
            .forEach(img => img.classList.remove('active-thumb'));

        element.classList.add('active-thumb');
    }


    // =========================
    // PREVIEW IMAGEN MODAL
    // =========================
    document.addEventListener("DOMContentLoaded", function() {

        const inputFile = document.getElementById("fileImage");

        if (inputFile) {
            inputFile.addEventListener("change", function() {

                const files = this.files;

                for (let file of files) {

                    const reader = new FileReader();

                    reader.onload = function(e) {
                        imagenesEditando.push(e.target.result);
                        renderPreviewEditable();
                    };

                    reader.readAsDataURL(file);
                }

                this.value = "";

            });
        }

        cargarProductos();
    });


    // =========================
    // CARGAR PRODUCTOS DESDE API
    // =========================
    async function cargarProductos() {

        const contenedor = document.getElementById("contenedorProductos");

        if (!contenedor) return;

        try {
            const response = await fetch("https://mi-proyecto1-2.onrender.com/api/registros");
            const data = await response.json();

            contenedor.innerHTML = "";

            data.forEach(item => {

                contenedor.innerHTML += `
            <div class="product-gallery">

            <div class="tipo-equipo-badge">
        ${item.tipo_Equipo}
    </div>

                <div class="main-image-container">
                    <img id="main-${item.id}"
                  src="${item.url_Equipo}"
                  class="main-product-image"
                  style="cursor:pointer"
                      onclick="zoomImage([
        '${item.url_Equipo}',
        '${item.url1}',
        '${item.url2}',
        '${item.url3}'
    ].filter(x => x), 0)" />
                </div>

                <div class="thumbnail-container">

                    ${item.url_Equipo ? `
                        <img src="${item.url_Equipo}"
                             class="thumbnail-image active-thumb"
                              onclick="changeImage(this, 'main-${item.id}')" />
                    ` : ""}

                    ${item.url1 ? `
                        <img src="${item.url1}"
                             class="thumbnail-image"
                              onclick="changeImage(this, 'main-${item.id}')"/>
                    ` : ""}

                    ${item.url2 ? `
                        <img src="${item.url2}"
                             class="thumbnail-image"
                              onclick="changeImage(this, 'main-${item.id}')" />
                    ` : ""}

                    ${item.url3 ? `
                        <img src="${item.url3}"
                             class="thumbnail-image"
                              onclick="changeImage(this, 'main-${item.id}')" />
                    ` : ""}

                </div>

                <h4>${item.modelo}</h4>
                <p>${item.descripcion}</p>
                <p>S/. ${item.precio}</p>


                    ${estaLogueado ? `
        <button class="btn btn-warning btn-sm w-100 mt-2"
                onclick="editarEquipo(${item.id})">
            Editar
        </button>
    ` : ``}


            </div>
        `;
            });

        } catch (error) {
            console.error("Error cargando productos:", error);
        }
    }


    // =========================
    // GUARDAR EQUIPO (CLOUDINARY + API)
    // =========================
    async function guardarEquipo() {

        const files = document.getElementById("fileImage").files;

        if (files.length === 0) {
            alert("Selecciona al menos una imagen");
            return;
        }

        try {


            // =========================
            // SUBIR IMÁGENES A CLOUDINARY
            // =========================
            for (let file of files) {

                const formData = new FormData();
                formData.append("file", file);
                formData.append("upload_preset", "inventario_preset");

                const cloudResponse = await fetch(
                    "https://api.cloudinary.com/v1_1/dkxto4ymq/image/upload", {
                        method: "POST",
                        body: formData
                    }
                );

                const cloudData = await cloudResponse.json();

                urls.push(cloudData.secure_url);
            }

            // =========================
            // ENVIAR A TU API
            // =========================
            await fetch("https://mi-proyecto1-2.onrender.com/api/registros", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({
                    tipo_Equipo: document.getElementById("tipoEquipo").value,
                    color: document.getElementById("color").value,
                    modelo: document.getElementById("modelo").value,
                    descripcion: document.getElementById("descripcion").value,
                    precio: parseFloat(document.getElementById("precio").value),

                    url_Equipo: urls[0] || "",
                    url1: urls[1] || "",
                    url2: urls[2] || "",
                    url3: urls[3] || ""
                })
            });

            alert("Equipo guardado correctamente");

            document.getElementById("modalAgregar")
                .querySelector(".btn-close")
                .click();

            cargarProductos();

        } catch (error) {
            console.error(error);
            alert("Error al guardar el equipo");
        }
    }


        function zoomImage(lista, index) {

        imagenesZoom = lista;
        indexZoom = index;

        actualizarZoom();

        const modalEl = document.getElementById("modalZoom");
        const modal = new bootstrap.Modal(modalEl);
        modal.show();
    }


    async function editarEquipo(id) {

        imagenesEditando = [];

        document.getElementById("fileImage").value = "";
        document.getElementById("previewContainer").innerHTML = "";

        const response = await fetch(`https://mi-proyecto1-2.onrender.com/api/registros`);
        const data = await response.json();

        const item = data.find(x => x.id === id);

        imagenesEditando = [
            item.url_Equipo,
            item.url1,
            item.url2,
            item.url3
        ].filter(x => x);

        if (!item) return;

        // llenar formulario
        document.getElementById("tipoEquipo").value = item.tipo_Equipo;
        document.getElementById("color").value = item.color;
        document.getElementById("modelo").value = item.modelo;
        document.getElementById("descripcion").value = item.descripcion;
        document.getElementById("precio").value = item.precio;

        renderPreviewEditable();

        // abrir modal
        const modal = new bootstrap.Modal(document.getElementById("modalAgregar"));
        modal.show();

        // cambiar botón a modo editar
        const btn = document.querySelector("#modalAgregar .btn-primary");

        btn.innerText = "Actualizar";
        btn.onclick = function() {
            actualizarEquipo(id);
        };
    }


    async function actualizarEquipo(id) {

        let urls = [];

        // 1. construir URLs primero
        for (let img of imagenesEditando) {

            if (img.startsWith("http")) {
                urls.push(img);
                continue;
            }

            const blob = await fetch(img).then(r => r.blob());

            const formData = new FormData();
            formData.append("file", blob);
            formData.append("upload_preset", "inventario_preset");

            const cloudResponse = await fetch(
                "https://api.cloudinary.com/v1_1/dkxto4ymq/image/upload", {
                    method: "POST",
                    body: formData
                }
            );

            const cloudData = await cloudResponse.json();
            urls.push(cloudData.secure_url);
        }

        urls = urls.slice(0, 4);

        // 2. ahora sí construir body
        let body = {
            tipo_Equipo: document.getElementById("tipoEquipo").value,
            color: document.getElementById("color").value,
            modelo: document.getElementById("modelo").value,
            descripcion: document.getElementById("descripcion").value,
            precio: parseFloat(document.getElementById("precio").value),

            url_Equipo: urls[0] || "",
            url1: urls[1] || "",
            url2: urls[2] || "",
            url3: urls[3] || ""
        };

        const response = await fetch(
            `https://mi-proyecto1-2.onrender.com/api/EditarEquipos/${id}`, {
                method: "PATCH",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(body)
            }
        );

        if (!response.ok) {
            console.error(await response.text());
            alert("Error al actualizar");
            return;
        }

        alert("Actualizado correctamente");

        bootstrap.Modal
            .getInstance(document.getElementById("modalAgregar"))
            .hide();

        cargarProductos();
    }

    ///


    function renderPreviewEditable() {

        const container = document.getElementById("previewContainer");
        container.innerHTML = "";

        imagenesEditando.forEach((url, index) => {


            const div = document.createElement("div");
            div.style.position = "relative";

            div.draggable = true;

                div.addEventListener("dragstart", () => {
        indiceArrastrado = index;
    });

        div.addEventListener("dragover", (e) => {
        e.preventDefault();
    });

        div.addEventListener("drop", () => {

        if (indiceArrastrado === null) return;

        const temp = imagenesEditando[indiceArrastrado];

        imagenesEditando[indiceArrastrado] =
            imagenesEditando[index];

        imagenesEditando[index] = temp;

        renderPreviewEditable();
    });

            div.innerHTML = `
                <img src="${url}"
                     style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid #ddd;" />

                <button type="button"
                    style="
                        position:absolute;
                        top:-8px;
                        right:-8px;
                        background:red;
                        color:white;
                        border:none;
                        border-radius:50%;
                        width:20px;
                        height:20px;
                        font-size:12px;
                        cursor:pointer;">
                    ×
                </button>
            `;

            div.querySelector("button").onclick = () => {
                imagenesEditando.splice(index, 1);
                renderPreviewEditable();
            };


            container.appendChild(div);
        });
    }

    document.getElementById("modalAgregar").addEventListener("show.bs.modal", function(event) {

        // Solo si estás en modo "crear", no editar
        const btn = document.querySelector("#modalAgregar .btn-primary");

        if (btn.innerText === "Guardar Equipo") {

            imagenesEditando = [];
            document.getElementById("previewContainer").innerHTML = "";
        }
    });

        function actualizarZoom() {

        const img = document.getElementById("imgZoom");
        img.src = imagenesZoom[indexZoom];

        document.getElementById("btnPrev").style.display =
            indexZoom > 0 ? "block" : "none";

        document.getElementById("btnNext").style.display =
            indexZoom < imagenesZoom.length - 1 ? "block" : "none";
    }

        function nextImage() {
        if (indexZoom < imagenesZoom.length - 1) {
            indexZoom++;
            actualizarZoom();
        }
    }

    function prevImage() {
        if (indexZoom > 0) {
            indexZoom--;
            actualizarZoom();
        }
    }

        document.addEventListener("keydown", function (e) {

        const modal = document.getElementById("modalZoom");

        if (!modal.classList.contains("show")) return;

        if (e.key === "ArrowRight") nextImage();
        if (e.key === "ArrowLeft") prevImage();
    });
</script>